</nav>

<script>
gsap.registerPlugin(ScrollTrigger);

/* ── cursor ── */
const dot=document.getElementById('cursor-dot');
const ring=document.getElementById('cursor-ring');
let mx=innerWidth/2,my=innerHeight/2,rx=mx,ry=my;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;});
(function tick(){rx+=(mx-rx)*.11;ry+=(my-ry)*.11;dot.style.left=mx+'px';dot.style.top=my+'px';ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(tick);})();
document.querySelectorAll('a').forEach(el=>{el.addEventListener('mouseenter',()=>ring.classList.add('grow'));el.addEventListener('mouseleave',()=>ring.classList.remove('grow'));});

/* ── progress bar ── */
const bar=document.getElementById('progress-bar');
window.addEventListener('scroll',()=>{const p=window.scrollY/(document.body.scrollHeight-innerHeight);bar.style.width=(p*100)+'%';});

/* ── reveals ── */
document.querySelectorAll('.reveal').forEach((el,i)=>{
  gsap.fromTo(el,{opacity:0,y:32},{
    opacity:1,y:0,duration:.9,ease:'power3.out',
    scrollTrigger:{trigger:el,start:'top 82%',toggleActions:'play none none reverse'}
  });
});

/* ── hero canvas — hex tunnel ── */
(()=>{
  const c=document.getElementById('hero-canvas');
  const ctx=c.getContext('2d');
  let W,H;
  const rsz=()=>{W=c.width=innerWidth;H=c.height=innerHeight;};
  rsz();addEventListener('resize',rsz);

  // Tunnel config — exact colours from the artwork shapes
  const LAYERS    = 18;
  const COLS      = [
    '227,103,167',    // #E367A7 — pink/magenta
    '252,179,26',     // #FCB31A — amber yellow
    '45,169,225',     // #2DA9E1 — sky blue
    '148,208,168',    // #94D0A8 — sage green
    '45,153,198',     // #2D99C6 — mid blue
    '96,190,119',     // #60BE77 — fresh green
  ];
  const BASE_ROT  = Math.PI/6;

  // Particles drifting out of the tunnel centre
  const pts=[];
  for(let i=0;i<260;i++){
    pts.push({
      // start near centre, random angle
      ang:Math.random()*Math.PI*2,
      dist:Math.random()*.15,        // fractional distance from centre (0=centre,1=edge)
      speed:0.0004+Math.random()*.0012,
      r:Math.random()*1.8+.4,
      alpha:.06+Math.random()*.22,
      col:['227,103,167','252,179,26','45,169,225','148,208,168','45,153,198','96,190,119'][Math.floor(Math.random()*6)],
    });
  }

  function drawHex(cx,cy,radius,rot,col,alpha,lw){
    ctx.beginPath();
    for(let i=0;i<=6;i++){
      const a=rot+(Math.PI/3)*i;
      const px=cx+Math.cos(a)*radius;
      const py=cy+Math.sin(a)*radius;
      i===0?ctx.moveTo(px,py):ctx.lineTo(px,py);
    }
    ctx.strokeStyle=`rgba(${col},${alpha})`;
    ctx.lineWidth=lw;
    ctx.stroke();
  }

  let t=0;
  (function draw(){
    requestAnimationFrame(draw);
    t+=.007;

    ctx.clearRect(0,0,W,H);

    // Dark radial bg — deeper at edges
    const bg=ctx.createRadialGradient(W*.5,H*.5,0,W*.5,H*.5,Math.max(W,H)*.72);
    bg.addColorStop(0,'rgba(28,8,48,.85)');
    bg.addColorStop(.5,'rgba(12,6,22,.92)');
    bg.addColorStop(1,'rgba(4,2,10,1)');
    ctx.fillStyle=bg;
    ctx.fillRect(0,0,W,H);

    // Vanishing point — slightly above centre, left-biased (text is on the right)
    const vx=W*.38, vy=H*.46;

    // Max radius: large enough to bleed off screen
    const maxR=Math.max(W,H)*.78;

    // Draw tunnel rings back-to-front (smallest = furthest away first)
    for(let i=0;i<LAYERS;i++){
      // Each ring's scale: exponential so perspective feels real
      // i=0 → tiny (far), i=LAYERS-1 → huge (close)
      const progress=i/(LAYERS-1);                     // 0..1
      const scale=Math.pow(progress,1.6);              // exponential grow
      const radius=8+scale*maxR;

      // Slowly rotate the whole tunnel
      const rot=BASE_ROT + t*0.08 + i*0.012;

      // Colour cycles through palette per ring + time
      const colIdx=Math.floor((i + t*1.2))%COLS.length;
      const col=COLS[colIdx];

      // Front rings: thicker + brighter; back rings: thin + faint
      const alpha=0.04+scale*.55;
      const lw=0.8+scale*5.5;

      drawHex(vx,vy,radius,rot,col,alpha,lw);

      // Draw connecting spoke lines from ring to ring for tunnel depth feel
      if(i>0){
        const prevScale=Math.pow((i-1)/(LAYERS-1),1.6);
        const prevR=8+prevScale*maxR;
        const prevRot=BASE_ROT + t*0.08 + (i-1)*0.012;
        const spokeAlpha=0.04+scale*.18;
        ctx.strokeStyle=`rgba(${col},${spokeAlpha})`;
        ctx.lineWidth=0.6+scale*1.2;
        for(let s=0;s<6;s++){
          const a1=rot+(Math.PI/3)*s;
          const a2=prevRot+(Math.PI/3)*s;
          ctx.beginPath();
          ctx.moveTo(vx+Math.cos(a1)*radius, vy+Math.sin(a1)*radius);
          ctx.lineTo(vx+Math.cos(a2)*prevR,  vy+Math.sin(a2)*prevR);
          ctx.stroke();
        }
      }
    }

    // Particles flying outward from vanishing point
    pts.forEach(p=>{
      p.dist+=p.speed;
      if(p.dist>0.95){p.dist=0;p.ang=Math.random()*Math.PI*2;}
      const px=vx+Math.cos(p.ang)*p.dist*maxR;
      const py=vy+Math.sin(p.ang)*p.dist*maxR;
      // fade in then fade out
      const fade=p.dist<.1?p.dist/.1:p.dist>.75?(1-p.dist)/.25:1;
      ctx.beginPath();
      ctx.arc(px,py,p.r,0,Math.PI*2);
      ctx.fillStyle=`rgba(${p.col},${p.alpha*fade})`;
      ctx.fill();
    });

    // Bright glow at vanishing point
    const glow=ctx.createRadialGradient(vx,vy,0,vx,vy,80);
    glow.addColorStop(0,'rgba(227,103,167,.2)');
    glow.addColorStop(.4,'rgba(252,179,26,.07)');
    glow.addColorStop(1,'rgba(0,0,0,0)');
    ctx.fillStyle=glow;
    ctx.fillRect(0,0,W,H);
  })();
})();
</script>
</body>
</html>
